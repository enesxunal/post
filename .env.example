NEXT_PUBLIC_APP_NAME=PostName
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (URL ZORUNLU DEĞİL — proje kodu yeterli) ---
NEXT_PUBLIC_SUPABASE_PROJECT_ID=jpavgsimjqbkukwevnl

# Settings > API Keys > Publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Settings > API Keys > Secret key (sb_secret_...)
SUPABASE_SECRET_KEY=

# İstersen URL de yazabilirsin (zorunlu değil):
# NEXT_PUBLIC_SUPABASE_URL=https://jpavgsimjqbkukwevnl.supabase.co
# Supabase Auth > Google provider icin Vercel callback URL:
# https://your-domain.com/auth/callback

# --- AI ---
# Görsel: openai | ideogram | gemini
IMAGE_PROVIDER=openai
OPENAI_API_KEY=
# gpt-image-1.5 (önerilen) | gpt-image-1 | gpt-image-1-mini | dall-e-3
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_FALLBACK_MODEL=gpt-image-1-mini
# DALL-E 3: standard | hd — GPT Image: low | medium | high
OPENAI_IMAGE_QUALITY=medium
# DALL-E 3 only: vivid | natural
OPENAI_IMAGE_STYLE=vivid
# false (varsayılan): AI başlığı görsele yazar | true: metinsiz arka plan + programatik bindirme
OPENAI_TEXT_FREE=false

IDEOGRAM_API_KEY=
# TURBO | DEFAULT | QUALITY (önerilen: DEFAULT — fiyat/kalite dengesi)
IDEOGRAM_RENDERING_SPEED=DEFAULT

# Caption + yazım kalite kontrolü için Gemini (görsel üretmez)
GEMINI_API_KEY=
CAPTION_PROVIDER=gemini
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Eski görsel motoru (IMAGE_PROVIDER=gemini ise)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Lean mod (varsayılan): post başına 1 görsel isteği, retry yok, vision QC kapalı
# Tam kalite için: LEAN_GENERATION_MODE=false
LEAN_GENERATION_MODE=true

# Eski / alternatif (kullanma):
# IMAGE_PROVIDER_API_KEY=

EMAIL_PROVIDER_API_KEY=

# Admin — EFT onay paneli (/admin/orders)
ADMIN_EMAILS=enesunal700@gmail.com

# Arka plan görsel üretim kuyruğu + cron (Vercel otomatik ekler)
CRON_SECRET=

# EFT banka bilgileri (opsiyonel, varsayılanlar kodda)
# EFT_ACCOUNT_HOLDER=Enes Ünal
# EFT_IBAN=TR30 0015 7000 0000 0088 1765 55
# EFT_BANK_NAME=Enpara
TOSLA_ENV=production
TOSLA_CLIENT_ID=
TOSLA_API_USER=
TOSLA_API_PASS=
# Opsiyonel — varsayılan: NEXT_PUBLIC_APP_URL/api/payments/tosla/callback
# TOSLA_CALLBACK_URL=https://post-murex.vercel.app/api/payments/tosla/callback
